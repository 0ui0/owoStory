---
layout: layout
---
<article class="post-card post-detail">
  <div class="post-card-body">
    <h1 class="post-title"><%= page.title %></h1>
    
    <!-- 标题下方的非标准直线：橙红色半六边形齿轮部分靠右，两侧为蓝色直线，末端大圆环 -->
    <div class="decor-line-wrapper">
      <svg class="decor-line-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 20" width="100%" height="20" preserveAspectRatio="none">
        <path d="M 0 10 L 240 10" fill="none" stroke="#2C77AE" stroke-width="1.5" />
        <path d="M 240 10 L 245 4 L 255 4 L 260 10 L 270 10 L 275 4 L 285 4 L 290 10 L 300 10" fill="none" stroke="#ff6b6b" stroke-width="1.5" />
        <path d="M 300 10 L 378 10" fill="none" stroke="#2C77AE" stroke-width="1.5" />
        <circle cx="388" cy="10" r="7.5" fill="none" stroke="#2C77AE" stroke-width="1.5" />
      </svg>
    </div>

    <!-- 装饰框：三个并排空心正方形 -->
    <div class="title-squares">
      <div class="decor-square"></div>
      <div class="decor-square"></div>
      <div class="decor-square"></div>
    </div>
    
    <div class="post-card-meta">
      <span class="post-date">
        <i class="far fa-calendar-alt"></i>
        <%= date(page.date, 'YYYY-MM-DD') %>
      </span>
      <% if (page.categories && page.categories.length) { %>
        <span class="post-categories">
          <i class="far fa-folder-open"></i>
          <% page.categories.each(function(cat) { %>
            <a href="<%= url_for(cat.path) %>"><%= cat.name %></a>
          <% }) %>
        </span>
      <% } %>
      <% if (page.tags && page.tags.length) { %>
        <span class="post-tags">
          <i class="fas fa-tags"></i>
          <% page.tags.each(function(tag) { %>
            <a href="<%= url_for(tag.path) %>"><%= tag.name %></a>
          <% }) %>
        </span>
      <% } %>
    </div>
    
    <%- partial('partial/post_thumbs', {post: page}) %>
    
    <div class="post-content">
      <%- page.content %>
    </div>
  </div>
</article>
