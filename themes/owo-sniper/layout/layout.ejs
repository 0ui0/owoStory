<!DOCTYPE html>
<html lang="<%= config.language %>">
<head>
  <%- partial('partial/head') %>
  <%- css('css/viewer.min.css') %>
  <% 
    var themeColor = theme.theme_color || '#2C77AE';
    var rgb = [44, 119, 174];
    try {
      var c = themeColor.replace(/^#/, '');
      if (c.length === 3) {
        c = c[0] + c[0] + c[1] + c[1] + c[2] + c[2];
      }
      var num = parseInt(c, 16);
      if (!isNaN(num)) {
        rgb = [ (num >> 16) & 255, (num >> 8) & 255, num & 255 ];
      }
    } catch(e) {}
  %>
  <style>
    :root {
      --primary-blue: <%= themeColor %> !important;
      --primary-blue-rgb: <%= rgb.join(',') %> !important;
      --primary-blue-alpha: rgba(<%= rgb.join(',') %>, 0.7) !important;
      --border-blue-alpha: rgba(<%= rgb.join(',') %>, 0.2) !important;
    }
    <% if (theme.character && theme.character.bg) { %>
      <% if (theme.character.bg.pc) { %>
        @media (min-width: 769px) {
          .sitting-boy-bg {
            <%= theme.character.bg.pc.left !== undefined ? 'left: ' + theme.character.bg.pc.left + ' !important;' : '' %>
            <%= theme.character.bg.pc.width !== undefined ? 'width: ' + theme.character.bg.pc.width + ' !important;' : '' %>
            <%= theme.character.bg.pc.bottom !== undefined ? 'bottom: ' + theme.character.bg.pc.bottom + ' !important;' : '' %>
            <%= theme.character.bg.pc.opacity !== undefined ? 'opacity: ' + theme.character.bg.pc.opacity + ' !important;' : '' %>
          }
        }
      <% } %>
      <% if (theme.character.bg.mobile) { %>
        @media (max-width: 768px) {
          .sitting-boy-bg {
            <%= theme.character.bg.mobile.left !== undefined ? 'left: ' + theme.character.bg.mobile.left + ' !important;' : 'left: auto !important;' %>
            <%= theme.character.bg.mobile.right !== undefined ? 'right: ' + theme.character.bg.mobile.right + ' !important;' : '' %>
            <%= theme.character.bg.mobile.bottom !== undefined ? 'bottom: ' + theme.character.bg.mobile.bottom + ' !important;' : '' %>
            <%= theme.character.bg.mobile.width !== undefined ? 'width: ' + theme.character.bg.mobile.width + ' !important;' : '' %>
            <%= theme.character.bg.mobile.opacity !== undefined ? 'opacity: ' + theme.character.bg.mobile.opacity + ' !important;' : '' %>
          }
        }
      <% } %>
    <% } %>
  </style>
</head>
<body>
  <!-- 背景插画：坐着的少年 (置于最底层) -->
  <div class="sitting-boy-bg">
    <img src="<%- url_for(theme.character && theme.character.background ? theme.character.background : 'images/sitting-boy.svg') %>" alt="Sitting Character">
  </div>

  <!-- 前景插画：狙击枪的少年 (独立层叠上下文，不受 sidebar-wall 约束，移动端专用) -->
  <% 
    var mobileStyle = '';
    if (theme.character && theme.character.mobile) {
      if (theme.character.mobile.left !== undefined) mobileStyle += 'left: ' + theme.character.mobile.left + ';';
      if (theme.character.mobile.height !== undefined) mobileStyle += 'height: ' + theme.character.mobile.height + ';';
      if (theme.character.mobile.bottom !== undefined) mobileStyle += 'bottom: ' + theme.character.mobile.bottom + ';';
    }
  %>
  <div class="sniper-boy-fg mobile-only-boy" style="<%= mobileStyle %>">
    <img src="<%- url_for(theme.character && theme.character.foreground ? theme.character.foreground : 'images/sniper-boy.svg') %>" alt="Foreground Character">
  </div>

  <!-- 主页面容器 -->
  <div class="app-container">
    <!-- 侧边栏/半圆轮盘导航 -->
    <%- partial('partial/header') %>
    
    <!-- 右侧主要内容区域 -->
    <main class="main-content">
      <div class="content-container">
        <%- body %>
        <%- partial('partial/footer') %>
      </div>
    </main>
  </div>

  <script src="<%- url_for('js/viewer.min.js') %>"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // 拦截九宫格 <a> 标签的默认在新窗口打开大图行为，改为触发内部图片的 click 激活 Viewer.js
      document.addEventListener('click', function(e) {
        var link = e.target.closest('.post-thumb-link');
        if (link) {
          e.preventDefault();
          var img = link.querySelector('img');
          if (img) {
            img.click();
          }
        }
      });

      // 初始化 Viewer.js
      var containers = document.querySelectorAll('.post-content, .post-card-excerpt, .post-card-thumbs');
      containers.forEach(function(container) {
        new Viewer(container, {
          // 仅过滤出文章内容或摘要中的大图，排除立绘与背景小图标
          filter: function(image) {
            return !image.closest('.sniper-boy-fg') && !image.closest('.sitting-boy-bg');
          },
          // 适应屏幕模式
          viewMode: 1, 
          // 允许放大至 10 倍，便于看清长图小字
          maxZoomRatio: 10,
          minZoomRatio: 0.1,
          // 工具栏配置：显示全部实用的缩放、旋转和翻转功能
          toolbar: {
            zoomIn: 1,
            zoomOut: 1,
            oneToOne: 1,
            reset: 1,
            prev: 1,
            next: 1,
            rotateLeft: 1,
            rotateRight: 1,
            flipHorizontal: 1,
            flipVertical: 1
          }
        });
      });
    });
  </script>
</body>
</html>
