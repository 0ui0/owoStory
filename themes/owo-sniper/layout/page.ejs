---
layout: layout
---
<article class="post-card page-detail decor-corner-tr decor-corner-bl">
  <div class="post-card-body">
    <h1 class="page-title"><%= page.title %></h1>
    
    <!-- 标题下方的非标准直线：半六边形部分靠右，独立颜色，末端大圆环 -->
    <div class="decor-line-wrapper" style="display: flex; align-items: center; width: 100%; max-width: 400px; margin-bottom: 12px; margin-top: 8px;">
      <!-- 左侧自适应蓝色直线 -->
      <div style="flex-grow: 1; height: 1.5px; background-color: #2C77AE;"></div>
      <!-- 右侧靠右独立的半六边形 + 终点大圆环 -->
      <svg width="95" height="20" viewBox="0 0 95 20" style="flex-shrink: 0; margin-left: -1px;">
        <path d="M 0 10 L 5 10 L 11 4 L 26 4 L 32 10 L 40 10 L 46 4 L 61 4 L 67 10 L 78.5 10" fill="none" stroke="#E56E4C" stroke-width="1.5" stroke-linejoin="round"/>
        <circle cx="85" cy="10" r="6" fill="none" stroke="#2C77AE" stroke-width="2" />
      </svg>
    </div>

    <div class="post-content">
      <%- page.content %>
    </div>
  </div>
</article>
