<%
  var icons = {
    '首页': '<g transform="translate(0, 2)"><polygon points="50,90 80,75 80,45 50,60" fill="currentColor" opacity="0.8"/><polygon points="50,90 20,75 20,45 35,32.5 50,60" fill="currentColor" opacity="0.6"/><polygon points="35,32.5 50,60 80,45 65,17.5" fill="currentColor" opacity="1"/><polygon points="35,32.5 20,45 50,30 65,17.5" fill="currentColor" opacity="0.4"/></g>',
    '归档': '<g transform="translate(0, 6)"><polygon points="50,80 20,65 20,35 50,50" fill="currentColor" opacity="0.6"/><polygon points="50,80 80,65 80,35 50,50" fill="currentColor" opacity="0.8"/><polygon points="50,50 80,35 50,20 20,35" fill="currentColor" opacity="0.2"/><polygon points="20,35 50,20 35,5 5,20" fill="currentColor" opacity="1"/><polygon points="80,35 50,20 65,5 95,20" fill="currentColor" opacity="0.7"/></g>',
    '关于': '<g transform="translate(0, 0)"><polygon points="50,20 60,15 50,10 40,15" fill="currentColor" opacity="1"/><polygon points="50,30 60,25 60,15 50,20" fill="currentColor" opacity="0.8"/><polygon points="50,30 40,25 40,15 50,20" fill="currentColor" opacity="0.6"/><polygon points="50,45 60,40 50,35 40,40" fill="currentColor" opacity="1"/><polygon points="50,85 60,80 60,40 50,45" fill="currentColor" opacity="0.8"/><polygon points="50,85 40,80 40,40 50,45" fill="currentColor" opacity="0.6"/></g>'
  };
%>

<nav class="bottom-nav">
  <% if (theme.menu) { %>
    <% for (var name in theme.menu) { %>
      <% 
         var link = theme.menu[name];
         var isActive = false;
         if (link === '/' && is_home()) {
           isActive = true;
         } else if (link !== '/') {
           var cleanPath = page.path.replace(/index\.html$/, '');
           var cleanLink = link.replace(/^\/|\/$/g, '');
           if (cleanPath.startsWith(cleanLink)) {
             isActive = true;
           }
         }
         var iconSvg = icons[name] || '<circle cx="12" cy="12" r="10"></circle>';
      %>
      <a href="<%= url_for(link) %>" class="bottom-nav-item <%= isActive ? 'active' : '' %>">
        <svg class="bottom-nav-icon" viewBox="0 0 100 100" fill="none" stroke="none">
          <%- iconSvg %>
        </svg>
        <span class="bottom-nav-text"><%= name %></span>
      </a>
    <% } %>
  <% } %>
</nav>
