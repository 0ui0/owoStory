<%
  var icons = {
    '首页': '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline>',
    '归档': '<polyline points="21 8 21 21 3 21 3 8"></polyline><rect x="1" y="3" width="22" height="5" rx="1"></rect><line x1="10" y1="12" x2="14" y2="12"></line>',
    '关于': '<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle>'
  };
%>

<nav class="bottom-nav">
  <% if (theme.menu) { %>
    <% for (var name in theme.menu) { %>
      <% 
         var link = theme.menu[name];
         var isActive = false;
         if (link === '/' && is_home()) {
           isActive = true;
         } else if (link !== '/') {
           var cleanPath = page.path.replace(/index\.html$/, '');
           var cleanLink = link.replace(/^\/|\/$/g, '');
           if (cleanPath.startsWith(cleanLink)) {
             isActive = true;
           }
         }
         var iconSvg = icons[name] || '<circle cx="12" cy="12" r="10"></circle>';
      %>
      <a href="<%= url_for(link) %>" class="bottom-nav-item <%= isActive ? 'active' : '' %>">
        <svg class="bottom-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <%- iconSvg %>
        </svg>
        <span class="bottom-nav-text"><%= name %></span>
      </a>
    <% } %>
  <% } %>
</nav>
