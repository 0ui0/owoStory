<%
  var icons = {
    '首页': '<g transform="translate(0, 2)" fill="none" stroke="currentColor" stroke-width="6" stroke-linejoin="round" stroke-linecap="round"><polygon points="50,90 20,75 20,45 35,32.5 65,17.5 80,45 80,75" /><polyline points="35,32.5 50,60 80,45" /><line x1="50" y1="60" x2="50" y2="90" /><line x1="20" y1="45" x2="50" y2="60" /></g>',
    '归档': '<g transform="translate(0, 6)" fill="none" stroke="currentColor" stroke-width="6" stroke-linejoin="round" stroke-linecap="round"><polygon points="50,80 20,65 20,35 50,50 80,35 80,65" /><line x1="50" y1="80" x2="50" y2="50" /><polyline points="20,35 50,20 80,35" /><polyline points="20,35 5,20 35,5 50,20" /><polyline points="50,20 65,5 95,20 80,35" /></g>',
    '关于': '<g transform="translate(0, 0)" fill="none" stroke="currentColor" stroke-width="6" stroke-linejoin="round" stroke-linecap="round"><polygon points="50,10 40,15 40,25 50,30 60,25 60,15" /><polyline points="40,15 50,20 60,15" /><line x1="50" y1="20" x2="50" y2="30" /><polygon points="50,35 40,40 40,80 50,85 60,80 60,40" /><polyline points="40,40 50,45 60,40" /><line x1="50" y1="45" x2="50" y2="85" /></g>'
  };
%>

<nav class="bottom-nav">
  <% if (theme.menu) { %>
    <% for (var name in theme.menu) { %>
      <% 
         var link = theme.menu[name];
         var isActive = false;
         if (link === '/' && is_home()) {
           isActive = true;
         } else if (link !== '/') {
           var cleanPath = page.path.replace(/index\.html$/, '');
           var cleanLink = link.replace(/^\/|\/$/g, '');
           if (cleanPath.startsWith(cleanLink)) {
             isActive = true;
           }
         }
         var iconSvg = icons[name] || '<circle cx="12" cy="12" r="10"></circle>';
      %>
      <a href="<%= url_for(link) %>" class="bottom-nav-item <%= isActive ? 'active' : '' %>">
        <svg class="bottom-nav-icon" viewBox="0 0 100 100" fill="none" stroke="none">
          <%- iconSvg %>
        </svg>
        <span class="bottom-nav-text"><%= name %></span>
      </a>
    <% } %>
  <% } %>
</nav>
