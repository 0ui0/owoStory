<% if (page.total > 1) { %>
  <nav class="pagination">
    <% if (page.prev) { %>
      <a href="<%= url_for(page.prev_link) %>" class="pagination-prev">
        <i class="fas fa-chevron-left"></i>
      </a>
    <% } %>
    <span class="pagination-info"><%= page.current %> / <%= page.total %></span>
    <% if (page.next) { %>
      <a href="<%= url_for(page.next_link) %>" class="pagination-next">
        <i class="fas fa-chevron-right"></i>
      </a>
    <% } %>
  </nav>
<% } %>
