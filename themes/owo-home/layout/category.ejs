---
layout: layout
---
<section class="archive-page">
  <h1 class="archive-title">
    <i class="far fa-folder-open"></i> 分类：<%= page.category ? page.category.name : '' %>
  </h1>
  <% page.posts.each(function(post) { %>
    <div class="archive-item">
      <span class="archive-date"><%= date(post.date, 'YYYY-MM-DD') %></span>
      <a href="<%= url_for(post.path) %>" class="archive-link"><%= post.title %></a>
    </div>
  <% }) %>
</section>

<%- partial('partial/pagination') %>
